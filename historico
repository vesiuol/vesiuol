// ── helpers ───────────────────────────────────────────────────────
const pi = v => parseInt(String(v||'').replace(/[^0-9]/g,'')) || 0;

function fetchCSV(url) {
  return fetch(url)
    .then(r => { if (!r.ok) throw new Error('HTTP '+r.status); return r.text(); })
    .then(t  => Papa.parse(t.replace(/^\uFEFF/,''), {header:true, skipEmptyLines:true}).data)
    .catch(e => { console.error('fetchCSV falhou:', e); return []; });
}

function getRow(label) {
  return VIS.find(r => (r['']||'').trim() === label) || null;
}

function vals(row, anos, suffix) {
  if (!row) return anos.map(() => 0);
  return anos.map(a => pi(row[suffix ? a+suffix : a]));
}

function subVals(cats, ano) {
  const anos = ano ? [ano] : TODOS_ANOS;
  const result = {};
  cats.forEach(cat => {
    const row = VIS.find(r => (r['Idiomas']||'').trim() === cat);
    if (!row) return;
    result[cat] = anos.reduce((s,a) => s + pi(row[a+'_1']), 0);
  });
  return result;
}

function getIdiomas(ano) {
  const anos = ano ? [ano] : TODOS_ANOS;
  const result = {};
  VIS.forEach(r => {
    const lbl = (r['Idiomas']||'').trim();
    if (!lbl) return;
    if (CAT_IDIOMA_SKIP.includes(lbl)) return;
    if ([...CAT_COR,...CAT_GENERO,...CAT_NOTAS].includes(lbl)) return;
    const tot = anos.reduce((s,a) => s + pi(r[a+'_1']), 0);
    if (tot > 0) result[lbl] = (result[lbl]||0) + tot;
  });
  return result;
}

function getGenLivro(ano) {
  const anos = ano ? [ano] : TODOS_ANOS;
  const idx = VIS.findIndex(r => (r['']||'').trim() === 'Gêneros literários');
  if (idx < 0) return {};
  const result = {};
  VIS.slice(idx+1).forEach(r => {
    const lbl = (r['']||'').trim();
    if (!lbl) return;
    const tot = anos.reduce((s,a) => s + pi(r[a]), 0);
    if (tot > 0) result[lbl] = tot;
  });
  return result;
}

function getPaises(ano) {
  if (!ano) {
    const result = {};
    VIS.forEach(r => {
      const p = (r['Países']||'').trim();
      const v = pi(r['Total']);
      if (p && v > 0) result[p] = v;
    });
    return result;
  }
  const result = {};
  VIS.forEach(r => {
    const p = (r['Países']||'').trim();
    const v = pi(r[ano+'_2']);
    if (p && v > 0) result[p] = v;
  });
  return result;
}

function topN(obj, n) {
  return Object.entries(obj).sort((a,b)=>b[1]-a[1]).slice(0,n);
}

// KPIs globais calculados direto da VIS
function calcKpisGlobais() {
  const livRow = getRow('Livros');
  const pagRow = getRow('Páginas');
  const totalLivros = vals(livRow, TODOS_ANOS, '').reduce((a,b)=>a+b, 0);
  const totalPags   = vals(pagRow, TODOS_ANOS, '').reduce((a,b)=>a+b, 0);
  const idSet  = getIdiomas(null);
  const pSet   = getPaises(null);
  const notasAcum = subVals(CAT_NOTAS, null);
  const c5     = notasAcum['5'] || 0;
  return { totalLivros, totalPags, idiomas: Object.keys(idSet).length, paises: Object.keys(pSet).length, c5 };
}

// ── Chart factories ───────────────────────────────────────────────
function mkBar(id, labels, data, horizontal=false) {
  const el = document.getElementById(id); if (!el) return null;
  return new Chart(el, {
    type: 'bar',
    data: { labels, datasets: [{ data,
      backgroundColor: labels.map((_,i) => i === labels.length-1 && !horizontal ? GREEN : GREEN_LIGHT),
      borderRadius: 3, borderSkipped: false
    }]},
    options: {
      maintainAspectRatio: false,
      indexAxis: horizontal ? 'y' : 'x',
      plugins: {
        legend: { display: false },
        datalabels: {
          display: true, anchor: 'end', align: horizontal ? 'end' : 'top', clamp: true,
          color: BLACK, font: { family:'DM Sans', size:10, weight:'500' },
          formatter: v => v > 0 ? v : '',
        }
      },
      scales: {
        x: { grid:{color:'#eee',lineWidth:.7}, ticks:{font:{family:'DM Sans',size:10},color:'#666'}, border:{display:false} },
        y: { grid:{color:'#eee',lineWidth:.7}, ticks:{font:{family:'DM Sans',size:10},color:'#666'}, border:{display:false} },
      }
    }
  });
}

function mkLine(id, labels, data, fmt) {
  const el = document.getElementById(id); if (!el) return null;
  return new Chart(el, {
    type: 'line',
    data: { labels, datasets: [{ data,
      borderColor: GREEN, backgroundColor: GREEN+'22',
      borderWidth: 2.5, pointBackgroundColor: GREEN,
      pointBorderColor: WHITE, pointBorderWidth: 2,
      pointRadius: 5, fill: true, tension: .35
    }]},
    options: {
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        datalabels: {
          display: true, anchor: 'end', align: 'top',
          color: BLACK, font: { family:'DM Sans', size:9, weight:'500' },
          formatter: fmt || (v => v > 0 ? v : ''),
        }
      },
      scales: {
        x: { grid:{color:'#eee',lineWidth:.7}, ticks:{font:{family:'DM Sans',size:10},color:'#666'}, border:{display:false} },
        y: { grid:{color:'#eee',lineWidth:.7}, ticks:{font:{family:'DM Sans',size:10},color:'#666'}, border:{display:false}, beginAtZero:true },
      }
    }
  });
}

// Pizza com generateLabels canônico (decisão #005)
function mkPie(id, labels, data) {
  const el = document.getElementById(id); if (!el) return null;
  return new Chart(el, {
    type: 'doughnut',
    data: { labels, datasets: [{ data, backgroundColor: CORES10, borderWidth: 0 }] },
    options: {
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            font: { family: 'DM Sans', size: 11 },
            color: '#333',
            padding: 12,
            boxWidth: 12,
            boxHeight: 12,
            generateLabels: function(chart) {
              const d = chart.data;
              const total = d.datasets[0].data.reduce((a,b) => a + (Number(b)||0), 0);
              return d.labels.map((label, i) => {
                const val = Number(d.datasets[0].data[i]) || 0;
                const pct = total > 0 ? Math.round((val / total) * 100) : 0;
                return {
                  text: label + ' (' + pct + '%)',
                  fillStyle: d.datasets[0].backgroundColor[i],
                  strokeStyle: d.datasets[0].backgroundColor[i],
                  lineWidth: 0,
                  hidden: false,
                  index: i
                };
              });
            }
          }
        },
        datalabels: {
          display: ctx => {
            const data = ctx.dataset.data;
            const total = data.reduce((a,b) => a + (Number(b)||0), 0);
            return total > 0 && (Number(data[ctx.dataIndex])||0) / total >= 0.08;
          },
          formatter: (v, ctx) => {
            const total = ctx.dataset.data.reduce((a,b) => a + (Number(b)||0), 0);
            return total > 0 ? Math.round((Number(v)||0) / total * 100) + '%' : '';
          },
          color: WHITE,
          font: { family: 'DM Sans', size: 11, weight: 'bold' },
        }
      }
    }
  });
}

// ── Hamburger ─────────────────────────────────────────────────────
(function(){
  const btn=document.getElementById('nav-hamburger'), menu=document.getElementById('nav-mobile');
  if(!btn||!menu) return;
  btn.addEventListener('click',()=>{
    const open=menu.classList.toggle('open'), bars=btn.querySelectorAll('span');
    bars[0].style.transform = open ? 'translateY(7px) rotate(45deg)' : '';
    bars[1].style.opacity   = open ? '0' : '';
    bars[2].style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
  });
  menu.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{
    menu.classList.remove('open');
    btn.querySelectorAll('span').forEach(s=>{ s.style.transform=''; s.style.opacity=''; });
  }));
})();

// ── State ─────────────────────────────────────────────────────────
let VIS=[], anoCharts={}, leafMap=null;

// ── Init ──────────────────────────────────────────────────────────
async function init() {
  VIS = await fetchCSV(URL_VIS);
  console.log('VIS linhas:', VIS.length);
  buildStats();
  buildGerais();
  buildMap();
  buildYearFilter();
  renderAno('todos');
}

// ── Stats globais ─────────────────────────────────────────────────
function buildStats() {
  const k = calcKpisGlobais();
  set('stat-total',     k.totalLivros > 0 ? k.totalLivros : '—');
  set('stat-paginas',   k.totalPags   > 0 ? fmt(k.totalPags) : '—');
  set('stat-idiomas',   k.idiomas     > 0 ? k.idiomas : '—');
  set('stat-autores',   '—');
  set('stat-paises',    k.paises      > 0 ? k.paises : '—');
  set('stat-5estrelas', k.c5          > 0 ? k.c5 : '—');
}

function set(id, v) { const el=document.getElementById(id); if(el) el.textContent=v; }
function fmt(n) { return n>0 ? Number(n).toLocaleString('pt-BR') : '—'; }

// ── Visão geral ───────────────────────────────────────────────────
function buildGerais() {
  const hl = TODOS_ANOS.map(a => a==='2026' ? GREEN : GREEN_LIGHT);
  function mkBarVis(id, row, anos, fmtFn) {
    const el=document.getElementById(id); if(!el) return;
    const data = vals(row, anos, '');
    new Chart(el, {
      type:'bar',
      data:{ labels:anos, datasets:[{data, backgroundColor:hl.slice(-anos.length), borderRadius:3}] },
      options:{
        maintainAspectRatio:false,
        plugins:{
          legend:{display:false},
          datalabels:{
            display:true, anchor:'end', align:'top', clamp:true,
            color:BLACK, font:{family:'DM Sans',size:10,weight:'500'},
            formatter: fmtFn || (v=>v>0?v:'')
          }
        },
        scales:{
          x:{grid:{color:'#eee',lineWidth:.7},ticks:{font:{family:'DM Sans',size:10},color:'#666'},border:{display:false}},
          y:{grid:{color:'#eee',lineWidth:.7},ticks:{font:{family:'DM Sans',size:10},color:'#666'},border:{display:false}},
        }
      }
    });
  }
  mkBarVis('c-anos',    getRow('Livros'),                           TODOS_ANOS);
  mkBarVis('c-paginas', getRow('Páginas'),                          TODOS_ANOS, v=>v>0?v.toLocaleString('pt-BR'):'');
  mkBarVis('c-novos',   getRow('Autores lidos pela 1º vez'),        TODOS_ANOS);
  mkBarVis('c-lgbtq',   getRow('Protagonistas LGBTQIA+'),           TODOS_ANOS);
  mkBarVis('c-etnia',   getRow('Representatividade etnica/racial'), TODOS_ANOS);
  mkBarVis('c-own',     getRow('#OwnVoices'),                       TODOS_ANOS);
}

// ── Mapa ──────────────────────────────────────────────────────────
function buildMap() {
  if (leafMap) return;
  leafMap = L.map('hist-map',{scrollWheelZoom:false}).setView([20,10],2);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{
    attribution:'© OpenStreetMap contributors © CARTO', maxZoom:19
  }).addTo(leafMap);
  Object.entries(getPaises(null)).forEach(([p,v]) => {
    const c=COORDS[p]; if(!c) return;
    L.circleMarker(c,{
      radius:Math.max(5,Math.sqrt(v)*3.5),
      fillColor:GREEN, color:GREEN_LIGHT,
      weight:1.5, opacity:.9, fillOpacity:.7
    }).bindPopup(`<b>${p}</b><br>${v} livro${v>1?'s':''}`).addTo(leafMap);
  });
}

// ── Filtro de anos ────────────────────────────────────────────────
function buildYearFilter() {
  const wrap=document.getElementById('year-filter'); wrap.innerHTML='';
  function mkBtn(label, ano) {
    const b=document.createElement('button');
    b.className='year-btn'+(label==='Todos'?' selected':'');
    b.textContent=label;
    b.onclick=()=>{
      document.querySelectorAll('.year-btn').forEach(x=>x.classList.remove('selected'));
      b.classList.add('selected');
      renderAno(ano);
    };
    wrap.appendChild(b);
  }
  mkBtn('Todos','todos');
  ANOS_FILTRO.slice().reverse().forEach(a => mkBtn(a,a));
}

// ── Render ano ────────────────────────────────────────────────────
function renderAno(ano) {
  Object.values(anoCharts).forEach(c=>{ try{c.destroy();}catch(e){} });
  anoCharts={};

  const anos = ano==='todos' ? TODOS_ANOS : [ano];

  const livRow = getRow('Livros'), pagRow = getRow('Páginas');
  const livTot = vals(livRow, anos, '').reduce((a,b)=>a+b, 0);
  const pagTot = vals(pagRow, anos, '').reduce((a,b)=>a+b, 0);
  const idSet  = getIdiomas(ano==='todos' ? null : ano);
  const pSet   = getPaises(ano==='todos' ? null : ano);
  const notasD = subVals(CAT_NOTAS, ano==='todos' ? null : ano);
  const c5     = notasD['5'] || 0;

  set('a-livros',    livTot > 0 ? livTot : '—');
  set('a-paginas',   pagTot > 0 ? fmt(pagTot) : '—');
  set('a-idiomas',   Object.keys(idSet).length > 0 ? Object.keys(idSet).length : '—');
  set('a-autores',   '—');
  set('a-paises',    Object.keys(pSet).length  > 0 ? Object.keys(pSet).length : '—');
  set('a-5estrelas', c5 > 0 ? c5 : '—');

  const t1=document.getElementById('chart-title-cor');
  const t2=document.getElementById('chart-title-genero');
  if(t1) t1.textContent = ano==='todos' ? 'Evolução — livros por ano'  : 'Cor do escritor';
  if(t2) t2.textContent = ano==='todos' ? 'Evolução — páginas lidas'   : 'Gênero do escritor';

  if (ano === 'todos') {
    anoCharts['ac-cor'] = mkLine('ac-cor', TODOS_ANOS, vals(getRow('Livros'),  TODOS_ANOS, ''));
    anoCharts['ac-ga']  = mkLine('ac-ga',  TODOS_ANOS, vals(getRow('Páginas'), TODOS_ANOS, ''),
      v => v>0 ? v.toLocaleString('pt-BR') : '');

    const idE = topN(idSet, 10);
    anoCharts['ac-idioma'] = mkPie('ac-idioma', idE.map(e=>e[0]), idE.map(e=>e[1]));

    const genE = topN(getGenLivro(null), 10);
    anoCharts['ac-generos'] = mkBar('ac-generos', genE.map(e=>e[0]), genE.map(e=>e[1]), true);

    const pE = topN(pSet, 10);
    anoCharts['ac-paises-ano'] = mkBar('ac-paises-ano', pE.map(e=>e[0]), pE.map(e=>e[1]), true);

    const notaAcum = subVals(CAT_NOTAS, null);
    anoCharts['ac-stars'] = mkBar('ac-stars', CAT_NOTAS, CAT_NOTAS.map(k=>notaAcum[k]||0));

  } else {
    const corD = subVals(CAT_COR, ano);
    const corE = Object.entries(corD).filter(e=>e[1]>0);
    if (corE.length) anoCharts['ac-cor'] = mkPie('ac-cor', corE.map(e=>e[0]), corE.map(e=>e[1]));

    const genD = subVals(CAT_GENERO, ano);
    const genE0 = Object.entries(genD).filter(e=>e[1]>0);
    if (genE0.length) anoCharts['ac-ga'] = mkPie('ac-ga', genE0.map(e=>e[0]), genE0.map(e=>e[1]));

    const idE = topN(idSet, 10);
    if (idE.length) anoCharts['ac-idioma'] = mkPie('ac-idioma', idE.map(e=>e[0]), idE.map(e=>e[1]));

    const glE = topN(getGenLivro(ano), 10);
    if (glE.length) anoCharts['ac-generos'] = mkBar('ac-generos', glE.map(e=>e[0]), glE.map(e=>e[1]), true);

    const pE = topN(pSet, 10);
    if (pE.length) anoCharts['ac-paises-ano'] = mkBar('ac-paises-ano', pE.map(e=>e[0]), pE.map(e=>e[1]), true);

    const notaD = subVals(CAT_NOTAS, ano);
    anoCharts['ac-stars'] = mkBar('ac-stars', CAT_NOTAS, CAT_NOTAS.map(k=>notaD[k]||0));
  }
}

init();

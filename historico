<style>
:root {
  --white:       #ffffff;
  --black:       #000000;
  --green:       #849974;
  --green-dark:  #6b7d5e;
  --green-light: #a8b99a;
  --border:      #c8c8c8;
  --nav-border:  #c5c5a0;
  --muted:       #555555;
  --text:        #1a1a1a;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: var(--white);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  line-height: 1.5;
}

/* ─── NAV ─────────────────────────────────────────────── */
nav {
  position: sticky; top: 0; z-index: 200;
  background: var(--white);
  border-bottom: 1.5px solid var(--nav-border);
  padding: 0 2.5rem;
  display: flex; align-items: center;
  height: 52px;
}
.nav-dots { display: flex; gap: 6px; align-items: center; flex-shrink: 0; }
.nav-dots span {
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--border); display: block;
}
nav ul {
  list-style: none; display: flex;
  gap: 2rem; margin-left: auto;
}
nav ul a {
  color: var(--black); text-decoration: none;
  font-size: .78rem; letter-spacing: .12em;
  text-transform: uppercase; font-weight: 500;
  transition: color .2s;
}
nav ul a:hover { opacity: .5; }
nav ul a.active {
  background: var(--green); color: var(--white);
  padding: .28rem .7rem; border-radius: 3px; font-weight: 700;
}

/* hamburger */
.nav-hamburger {
  display: none; background: none; border: none;
  cursor: pointer; margin-left: auto; padding: .4rem;
  flex-direction: column; gap: 5px;
}
.nav-hamburger span {
  display: block; width: 22px; height: 2px;
  background: var(--black); border-radius: 2px;
  transition: all .25s;
}

/* menu mobile */
.nav-mobile {
  display: none; position: fixed;
  top: 52px; left: 0; right: 0; bottom: 0;
  background: var(--white); z-index: 199;
  flex-direction: column; padding: 2rem 1.5rem; gap: 0;
  border-top: 1px solid var(--border);
}
.nav-mobile.open { display: flex; }
.nav-mobile a {
  color: var(--black); text-decoration: none;
  font-size: 1.1rem; letter-spacing: .1em; text-transform: uppercase;
  font-weight: 400; padding: 1rem 0;
  border-bottom: 1px solid var(--border); display: block;
}
.nav-mobile a.active { color: var(--green); font-weight: 500; }
.nav-mobile a:last-child { border-bottom: none; }

/* ─── HERO ────────────────────────────────────────────── */
.hero-wrap {
  padding: 3rem 2.5rem 1.5rem;
  max-width: 1200px; margin: 0 auto;
}
.hero-card {
  border: 1.5px solid var(--black);
  border-radius: 14px; padding: 2.5rem 3rem;
}
.hero-card-dots { display: flex; gap: 5px; margin-bottom: 1.2rem; }
.hero-card-dots span {
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--border); display: block;
}
.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 600; line-height: 1.1;
  display: inline-block;
  background: var(--green); color: var(--white);
  padding: .1em .3em; margin-bottom: 1.2rem;
}
.hero-desc {
  font-size: .95rem; color: var(--text);
  line-height: 1.75; max-width: 800px; margin-bottom: 2rem;
}
.hero-divider {
  border: none; border-top: 1px solid var(--border);
  margin: 1.5rem -3rem;
}
.hero-sub { display: flex; justify-content: space-between; align-items: center; }
.hero-sub-text {
  font-size: .68rem; letter-spacing: .16em;
  text-transform: uppercase; color: var(--muted);
}
.hero-arrow { font-size: 1.4rem; color: var(--black); }

/* ─── STAT CARDS ─────────────────────────────────────── */
.stats-section {
  padding: 1.5rem 2.5rem;
  max-width: 1200px; margin: 0 auto;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: .6rem;
}
.stat-card {
  border: 1.5px solid var(--green-dark);
  border-radius: 10px;
  background: var(--green);
  padding: 1.5rem 1rem;
  text-align: center;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  min-height: 110px;
  box-shadow: 2px 2px 0 var(--green-dark);
}
.stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.4rem; font-weight: 600;
  color: var(--white); line-height: 1;
  display: block; margin-bottom: .4rem;
}
.stat-label {
  font-size: .65rem; letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--white); font-weight: 500;
}

/* ─── SECTION HEADER ─────────────────────────────────── */
.section-wrap {
  max-width: 1200px; margin: 0 auto;
  padding: 2.5rem 2.5rem 1.5rem;
}
.section-header {
  display: flex; align-items: center; gap: 1.2rem;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
  padding-bottom: 1rem;
}
.section-label {
  background: var(--green); color: var(--white);
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem; font-weight: 600;
  padding: .2rem .7rem; border-radius: 4px;
  white-space: nowrap;
}
.section-sub {
  font-size: .72rem; letter-spacing: .14em;
  text-transform: uppercase; color: var(--muted);
}

/* ─── CHART CARDS ────────────────────────────────────── */
.charts-col { display: flex; flex-direction: column; gap: 1rem; }
.chart-card {
  border: 1.5px solid var(--border);
  border-radius: 14px; padding: 1.5rem 2rem;
  background: var(--white);
  box-shadow: 2px 2px 0 var(--border);
}
.chart-card-header {
  display: flex; align-items: center;
  gap: .6rem; margin-bottom: 1.2rem;
}
.chart-card-dots { display: flex; gap: 4px; }
.chart-card-dots span {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--green-light); display: block;
}
.chart-card-title {
  font-size: .75rem; letter-spacing: .12em;
  text-transform: uppercase; color: var(--muted);
}
.chart-wrap { position: relative; height: 240px; }
.chart-wrap.tall { height: 320px; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

/* ─── MAP ────────────────────────────────────────────── */
#hist-map {
  height: 440px; border-radius: 10px;
  border: 1.5px solid var(--border);
}

/* ─── YEAR FILTER ────────────────────────────────────── */
.year-filter {
  display: flex; gap: .6rem;
  flex-wrap: wrap; margin-bottom: 2rem;
}
.year-btn {
  padding: .4rem 1.1rem;
  border: 1.5px solid var(--border);
  background: transparent;
  font-family: 'DM Sans', sans-serif;
  font-size: .82rem; font-weight: 400;
  border-radius: 100px; cursor: pointer;
  color: var(--muted);
  transition: all .2s;
}
.year-btn:hover {
  background: var(--green);
  border-color: var(--green);
  color: var(--white);
}
.year-btn.selected {
  background: var(--green);
  border-color: var(--green);
  color: var(--white);
}
.year-btn:focus { outline: none; }

/* ─── ANO STATS GRID ─────────────────────────────────── */
.ano-stats-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: .6rem; margin-bottom: 1.5rem;
}

/* ─── FOOTER ─────────────────────────────────────────── */
footer {
  background: var(--green);
  padding: 1.2rem 2.5rem;
  display: flex; align-items: center; gap: 1rem;
}
.footer-dots { display: flex; gap: 6px; }
.footer-dots span {
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--white); display: block;
}
.footer-text {
  font-size: .60rem; letter-spacing: .1em;
  text-transform: uppercase; font-weight: 500;
  color: var(--white);
}

/* ─── RESPONSIVE ─────────────────────────────────────── */
@media (max-width: 900px) {
  .stats-grid, .ano-stats-grid { grid-template-columns: repeat(3, 1fr); }
  .two-col { grid-template-columns: 1fr; }
  .hero-card { padding: 1.5rem; }
  .hero-divider { margin: 1.5rem -1.5rem; }
}

@media (max-width: 600px) {
  body { overflow-x: hidden; }

  /* Nav */
  nav { padding: 0 1rem; }
  nav ul { display: none; }
  .nav-hamburger { display: flex; }
  .nav-dots span { width: 8px; height: 8px; }

  /* Hero */
  .hero-wrap { padding: 1.2rem 1rem 1rem; }
  .hero-card { padding: 1.2rem; border-radius: 10px; }
  .hero-title { font-size: 2.2rem; }
  .hero-desc { font-size: .88rem; margin-bottom: 1.2rem; }
  .hero-sub-text { font-size: .6rem; }
  .hero-divider { margin: 1rem -1.2rem; }

  /* Stats */
  .stats-section { padding: 1rem; }
  .stats-grid, .ano-stats-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: .5rem;
  }
  .stat-card { min-height: 90px; padding: 1rem .6rem; border-radius: 8px; }
  .stat-num { font-size: 1.9rem; }
  .stat-label { font-size: .6rem; }

  /* Seções */
  .section-wrap { padding: 1.5rem 1rem 1rem; }
  .section-header { gap: .7rem; flex-wrap: wrap; }
  .section-label { font-size: 1rem; }

  /* Chart cards */
  .chart-card { padding: 1rem; border-radius: 10px; }
  .charts-col { gap: .8rem; }
  .two-col { grid-template-columns: 1fr; gap: .8rem; }
  .chart-wrap { height: 200px; }
  .chart-wrap.tall { height: 260px; }

  /* Mapa */
  #hist-map { height: 280px; border-radius: 8px; }

  /* Filtro */
  .year-filter { gap: .4rem; margin-bottom: 1.2rem; }
  .year-btn { padding: .35rem .8rem; font-size: .76rem; }

  /* Footer */
  footer { padding: 1rem; flex-wrap: wrap; gap: .5rem; }
}
</style>
</head>
